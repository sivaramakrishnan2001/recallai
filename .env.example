# =============================================================================
# .env Configuration Template
# Copy to .env and fill in your actual API keys
# =============================================================================

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-proj-...

# --- ElevenLabs TTS (required) ---
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Recall.ai (required for Teams bot) ---
RECALL_API_KEY=...

# --- ngrok (required for production) ---
# Get free auth token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=...

# --- n8n (optional: save results to Google Sheets) ---
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/interview-complete

# --- Recall.ai Bot Creation (optional: auto-create bot on startup) ---
# Set these to auto-create bot when you run start-prod.js
TEAMS_MEETING_URL=https://teams.microsoft.com/meet/xxxxx
BOT_ROLE=Software Engineer

# --- Server ---
PORT=3000
