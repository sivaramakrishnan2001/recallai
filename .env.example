# Server Configuration
PORT=3000
NODE_ENV=development

# Recall.ai Configuration
RECALL_API_KEY=your_recall_api_key_here
# Get from: https://app.recall.ai/settings/api-keys

# AWS Bedrock Configuration
BEDROCK_API_KEY=your_bedrock_secret_access_key_here
BEDROCK_API_KEY_NAME=your_bedrock_access_key_id_here
AWS_REGION=us-east-1
# Get from: AWS Console → IAM → Users → Create Access Keys

# n8n Webhook (Optional - for results logging)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/interview-complete
# Create a Webhook trigger in n8n and paste the URL here

# OpenAI (Optional - if using OpenAI Realtime API)
OPENAI_API_KEY=sk_realtime_xxxxxxxxxxxx
# Get from: https://platform.openai.com/api-keys
# Note: Must use sk_realtime_ keys, not sk-proj_ keys

# ElevenLabs (For bot voice/TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Get from: https://elevenlabs.io/app/speech-synthesis
# Voice ID: Default English voice